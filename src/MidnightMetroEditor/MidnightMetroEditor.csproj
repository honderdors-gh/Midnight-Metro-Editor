<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net6.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>MidnightMetroEditor</RootNamespace>
    <AssemblyName>MidnightMetroEditor</AssemblyName>
    <ApplicationIcon />
    <StartupObject>MidnightMetroEditor.Program</StartupObject>
    <Version>0.1.0</Version>
    <Authors>Midnight Line Studio</Authors>
    <Description>Save file editor for Midnight Metro.</Description>
  </PropertyGroup>
</Project>
